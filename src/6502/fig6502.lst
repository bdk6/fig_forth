                              1 ;
                              2 ;  This file is a modified version of FIG Forth.  I originally downloaded it here:
                              3 ;        http://www.6502.org/source/
                              4 ;
                              5 ;  with this description:
                              6 ;      FIG FORTH 6502 [FORTH65.ZIP: 32KB] from the FORTH Interest Group
                              7 ; 
                              8 ;      FORTH Interest Group (FIG) FORTH kernel for the 6502. It is written for the 
                              9 ;      Rockwell System-65 but is easily adaptable to your own systems. Note that 
                             10 ;      this has the "UM/MOD" division bug. An explanation of the bug and a correction 
                             11 ;      can be found in Garth Wilson's 32-bit Division entry, which can also be found 
                             12 ;      here in the Source Code Repository.
                             13 ;
                             14 ;  Here is the text from the included README.TXT file.
                             15 ;     FIG6502.ASM is the original FIG listing, for a Rockwell native assembler.
                             16 ;     FIG6502.ASX is my modified listing, which will assemble
                             17 ;       with MAS65 macro cross assembler, available from
                             18 ;       http://www2.whidbey.net/~beattidp/
                             19 ;
                             20 ;     04 JAN 2000  
                             21 ;     <beattidp@whidbey.net>
                             22 ;
                             23 ; All further changes in this file (FIG6502.as65) are by me.
                             24 ;
                             25 ; Changelog
                             26 ; 
                             27 ;   202509122     Translated to AS6500 by William R Cooke 20250919-20250922
                             28 ;
                             29 ; ************************** End of Changelog ********************************
                             30 ;
                             31 ;                        Through the courtesy of
                             32 ;
                             33 ;                         FORTH INTEREST GROUP
                             34 ;                            P.O. BOX  2154
                             35 ;                         OAKLAND, CALIFORNIA
                             36 ;                                94621
                             37 ;
                             38 ;
                             39 ;                             Release 1.1
                             40 ;
                             41 ;                        with compiler security
                             42 ;                                  and
                             43 ;                        variable length names
                             44 ;
                             45 ;    Further distribution must include the above notice.
                             46 ;    The FIG installation Manual is required as it contains
                             47 ;    the model of FORTH and glossary of the system.
                             48 ;    Available from FIG at the above address for **.** postpaid.
                             49 ;
                             50 ;    Translated from the FIG model by W.F. Ragsdale with input-
                             51 ;    output given for the Rockwell System-65. Transportation to
                             52 ;    other systems requires only the alteration of :
                             53 ;                 XEMIT, XKEY, XQTER, XCR, AND RSLW
                             54 ;
                             55 ;    Equates giving memory assignments, machine
ASxxxx Assembler V05.30  (Rockwell 6502/6510/65C02)                     Page 2
Hexadecimal [16-Bits]                                 Tue Sep 23 21:04:07 2025



                             56 ;    registers, and disk parameters.
                             57 ;
                             58           .AREA CODE1 (ABS)
                     0080    59 SSIZE     =128           ; sector size in bytes
                     0008    60 NBUF      =8             ; number of buffers desired in RAM
                             61 ;                             (SSIZE*NBUF >= 1024 bytes)
                     0320    62 SECTR     =800           ; sector per drive
                             63 ;                              forcing high drive to zero
                     0640    64 SECTL     =1600          ; sector limit for two drives
                             65 ;                              of 800 per drive.
                     0420    66 BMAG      =1056          ; total buffer magnitude, in bytes
                             67 ;                              expressed by SSIZE+4*NBUF
                             68 ;
                     0020    69 BOS       =0x20           ; bottom of data stack, in zero-page.
                     009E    70 TOS       =0x9E           ; top of data stack, in zero-page.
                     00A6    71 N         =TOS+8         ; scratch workspace.
                     00AE    72 IP        =N+8           ; interpretive pointer.
                     00B1    73 W         =IP+3          ; code field pointer.
                     00B3    74 UP        =W+2           ; user area pointer.
                     00B5    75 XSAVE     =UP+2          ; temporary for X register.
                             76 ;
                     0100    77 TIBX      =0x0100         ; terminal input buffer of 84 bytes.
                     0200    78 ORIG      =0x0200         ; origin of FORTH's Dictionary.
                     4000    79 MEM       =0x4000         ; top of assigned memory+1 byte.
                     3F80    80 UAREA     =MEM-128       ; 128 bytes of user area
                     3B60    81 DAREA     =UAREA-BMAG    ; disk buffer space.
                             82 ;
                             83 ;         Monitor calls for terminal support
                             84 ;
                     D2C1    85 OUTCH     =0xD2C1         ; output one ASCII char. to term.
                     D1DC    86 INCH      =0xD1DC         ; input one ASCII char. to term.
                     D0F1    87 TCR       =0xD0F1         ; terminal return and line feed.
                             88 ;
                             89 ;    From DAREA downward to the top of the dictionary is free
                             90 ;    space where the user's applications are compiled.
                             91 ;
                             92 ;    Boot up parameters. This area provides jump vectors
                             93 ;    to Boot up  code, and parameters describing the system.
                             94 ;
                             95 ;
   0200                      96            .ORG ORIG      ;          .=.+2
                             97 ;
                             98                          ; User cold entry point
   0200 EA            [ 2]   99 ENTER:     NOP            ; Vector to COLD entry
   0201 4C 63 12      [ 3]  100           JMP COLD+2     ;
   0204 EA            [ 2]  101 REENTR:    NOP            ; User Warm entry point
   0205 4C 73 12      [ 3]  102           JMP WARM       ; Vector to WARM entry
   0208 04 00               103           .WORD 0x0004    ; 6502 in radix-36
   020A D2 5E               104           .WORD 0x5ED2    ;
   020C 81 1A               105           .WORD NTOP     ; Name address of MON
   020E 7F 00               106           .WORD 0x7F      ; Backspace Character
   0210 80 3F               107           .WORD UAREA    ; Initial User Area
   0212 9E 00               108           .WORD TOS      ; Initial Top of Stack
   0214 FF 01               109           .WORD 0x1FF     ; Initial Top of Return Stack
   0216 00 01               110           .WORD TIBX     ; Initial terminal input buffer
