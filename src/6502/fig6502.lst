   025D 90 02         [ 4]  166           BCC L54
   025F E6 AF         [ 5]  167           INC IP+1
   0261 4C B0 00      [ 3]  168 L54:       JMP W-1        ;Jump to an indirect jump (W) which
                            169 ;                        ;vectors to code pointed to by a code
                            170 ;                        ;field.
                            171 ;
                            172 ;    CLIT pushes the next inline byte to data stack
                            173 ;
   0264 84                  174 L35:       .BYTE 0x84
   0265 43 4C 49            175            .ASCII 'CLI'
   0268 D4                  176            .BYTE  0xD4
   0269 24 02               177           .WORD L22      ; Link to LIT
   026B 6D 02               178 CLIT:      .WORD .+2
   026D B9 AE 00      [ 5]  179           LDA (IP),Y
   0270 48            [ 3]  180           PHA
   0271 98            [ 2]  181           TYA
   0272 F0 C5         [ 4]  182           BEQ L31        ; a forced branch into LIT
                            183 ;
                            184 ;
                            185 ;    This is a temporary trace routine, to be used until FORTH
                            186 ;    is generally operating. Then NOP the terminal query
                            187 ;    "JSR ONEKEY". This will allow user input to the text
                            188 ;    interpreter. When crashes occur, the display shows IP, W,
                            189 ;    and the word locations of the offending code. When all is
                            190 ;    well, remove : TRACE, TCOLON, PRNAM, DECNP, and the
                            191 ;    following monitor/register equates.
                            192 ;
                            193 ;
                            194 ;
                            195 ;    Monitor routines needed to trace.
                            196 ;
                     D0AF   197 XBLANK    =0xD0AF         ; print one blank
                     D0D2   198 CRLF      =0xD0D2         ; print a carriage return and line feed.
                     D2CE   199 HEX2      =0xD2CE         ; print accum as two hex numbers
                     D2C1   200 LETTER    =0xD2C1         ; print accum as one ASCII character
                     D1DC   201 ONEKEY    =0xD1DC         ; wait for keystroke
                     0012   202 XW        =0x12           ; scratch reg. to next code field add
                     0014   203 NP        =0x14           ; scratch reg. pointing to name field
                            204 ;
                            205 ;
   0274 86 B5         [ 3]  206 TRACE:     STX XSAVE
   0276 20 D2 D0      [ 6]  207           JSR CRLF
   0279 A5 AF         [ 3]  208           LDA IP+1
   027B 20 CE D2      [ 6]  209           JSR HEX2
   027E A5 AE         [ 3]  210           LDA IP
   0280 20 CE D2      [ 6]  211           JSR HEX2       ; print IP, the interpreter pointer
   0283 20 AF D0      [ 6]  212           JSR XBLANK
                            213 ;
                            214 ;
   0286 A9 00         [ 2]  215           LDA #0
   0288 B9 AE 00      [ 5]  216           LDA (IP),Y
   028B 85 12         [ 3]  217           STA XW
   028D 85 14         [ 3]  218           STA NP         ; fetch the next code field pointer
   028F C8            [ 2]  219           INY
   0290 B9 AE 00      [ 5]  220           LDA (IP),Y
ASxxxx Assembler V05.30  (Rockwell 6502/6510/65C02)                     Page 5
Hexadecimal [16-Bits]                                 Tue Sep 23 21:04:07 2025



   0293 85 13         [ 3]  221           STA XW+1
   0295 85 15         [ 3]  222           STA NP+1
   0297 20 E0 02      [ 6]  223           JSR PRNAM      ; print dictionary name
                            224 ;
   029A A5 13         [ 3]  225           LDA XW+1
   029C 20 CE D2      [ 6]  226           JSR HEX2       ; print code field address
   029F A5 12         [ 3]  227           LDA XW
   02A1 20 CE D2      [ 6]  228           JSR HEX2
   02A4 20 AF D0      [ 6]  229           JSR XBLANK
                            230 ;
   02A7 A5 B5         [ 3]  231           LDA XSAVE      ; print stack location in zero-page
   02A9 20 CE D2      [ 6]  232           JSR HEX2
   02AC 20 AF D0      [ 6]  233           JSR XBLANK
                            234 ;
   02AF A9 01         [ 2]  235           LDA #1         ; print return stack bottom in page 1
   02B1 20 CE D2      [ 6]  236           JSR HEX2
   02B4 BA            [ 2]  237           TSX
   02B5 E8            [ 2]  238           INX
   02B6 8A            [ 2]  239           TXA
   02B7 20 CE D2      [ 6]  240           JSR HEX2
   02BA 20 AF D0      [ 6]  241           JSR XBLANK
                            242 ;
   02BD 20 DC D1      [ 6]  243           JSR ONEKEY     ; wait for operator keystroke
   02C0 A6 B5         [ 3]  244           LDX XSAVE      ; just to pinpoint early problems
   02C2 A0 00         [ 2]  245           LDY #0
   02C4 60            [ 6]  246           RTS
                            247 ;
                            248 ;    TCOLON is called from DOCOLON to label each point
                            249 ;    where FORTH 'nests' one level.
                            250 ;
   02C5 86 B5         [ 3]  251 TCOLON:    STX XSAVE
   02C7 A5 B1         [ 3]  252           LDA W
   02C9 85 14         [ 3]  253           STA NP         ; locate the name of the called word
   02CB A5 B2         [ 3]  254           LDA W+1
   02CD 85 15         [ 3]  255           STA NP+1
   02CF 20 D2 D0      [ 6]  256           JSR CRLF
   02D2 A9 3A         [ 2]  257           LDA #0x3A       ; ':
   02D4 20 C1 D2      [ 6]  258           JSR LETTER
   02D7 20 AF D0      [ 6]  259           JSR XBLANK
   02DA 20 E0 02      [ 6]  260           JSR PRNAM
   02DD A6 B5         [ 3]  261           LDX XSAVE
   02DF 60            [ 6]  262           RTS
                            263 ;
                            264 ;    Print name by it's code field address in NP
                            265 ;
   02E0 20 05 03      [ 6]  266 PRNAM:     JSR DECNP
   02E3 20 05 03      [ 6]  267           JSR DECNP
   02E6 20 05 03      [ 6]  268           JSR DECNP
   02E9 A0 00         [ 2]  269           LDY #0
   02EB 20 05 03      [ 6]  270 PN1:       JSR DECNP
   02EE B9 14 00      [ 5]  271           LDA (NP),Y     ; loop till D7 in name set
   02F1 10 F8         [ 4]  272           BPL PN1
   02F3 C8            [ 2]  273 PN2:       INY
   02F4 B9 14 00      [ 5]  274           LDA (NP),Y
   02F7 20 C1 D2      [ 6]  275           JSR LETTER     ; print letters of name field
