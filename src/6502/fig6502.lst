                            111 ;
                            112 ;
   0218 1F 00               113           .WORD 31       ; Initial name field width
   021A 00 00               114           .WORD 0        ; 0=nod disk, 1=disk
   021C 91 1A               115           .WORD TOP      ; Initial fence address
   021E 91 1A               116           .WORD TOP      ; Initial top of dictionary
   0220 DA 11               117           .WORD VL0      ; Initial Vocabulary link ptr.
                            118 ;
                            119 ;    The following offset adjusts all code fields to avoid an
                            120 ;    address ending 0xXXFF. This must be checked and altered on
                            121 ;    any alteration , for the indirect jump at W-1 to operate !
                            122 ;
                     0224   123           . = .+2
                            124 ;
                            125 ;
                            126 ;                                       LIT
                            127 ;                                       SCREEN 13 LINE 1
                            128 ;
   0224 83                  129 L22:       .BYTE   0x83
   0225 4C 49               130            .ASCII  'LI'
   0227 D4                  131            .BYTE   0xD4            ; <--- name field
                            132 ;                          <----- link field
   0228 00 00               133           .WORD 00       ; last link marked by zero
   022A 2C 02               134 LIT:       .WORD .+2      ; <----- code address field
   022C B9 AE 00      [ 5]  135           LDA (IP),Y     ; <----- start of parameter field
   022F 48            [ 3]  136           PHA
   0230 E6 AE         [ 5]  137           INC IP
   0232 D0 02         [ 4]  138           BNE L30
   0234 E6 AF         [ 5]  139           INC IP+1
   0236 B9 AE 00      [ 5]  140 L30:       LDA (IP),Y
   0239 E6 AE         [ 5]  141 L31:       INC IP
   023B D0 02         [ 4]  142           BNE PUSH
   023D E6 AF         [ 5]  143           INC IP+1
                            144 ;
   023F CA            [ 2]  145 PUSH:      DEX
   0240 CA            [ 2]  146           DEX
                            147 ;
   0241 95 01         [ 4]  148 PUT:       STA 1,X
   0243 68            [ 4]  149           PLA
   0244 95 00         [ 4]  150           STA 0,X
                            151 ;
                            152 ;    NEXT is the address interpreter that moves from machine
                            153 ;    level word to word.
                            154 ;
   0246 A0 01         [ 2]  155 NEXT:      LDY #1
   0248 B9 AE 00      [ 5]  156           LDA (IP),Y     ; Fetch code field address pointed
   024B 85 B2         [ 3]  157           STA W+1        ; to by IP.
   024D 88            [ 2]  158           DEY
   024E B9 AE 00      [ 5]  159           LDA (IP),Y
   0251 85 B1         [ 3]  160           STA W
   0253 20 74 02      [ 6]  161           JSR TRACE      ; Remove this when all is well
   0256 18            [ 2]  162           CLC            ; Increment IP by two.
   0257 A5 AE         [ 3]  163           LDA IP
   0259 69 02         [ 2]  164           ADC #2
   025B 85 AE         [ 3]  165           STA IP
