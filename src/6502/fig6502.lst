   161B 91 B3         [ 6] 3559           STA [UP],Y
   161D B5 00         [ 4] 3560           LDA 0,X        ; fetch character to output
   161F 86 B5         [ 3] 3561           STX XSAVE
   1621 20 C1 D2      [ 6] 3562           JSR OUTCH      ; and display it
   1624 A6 B5         [ 3] 3563           LDX XSAVE
   1626 4C FA 03      [ 3] 3564           JMP POP
                           3565 ;
                           3566 ;         XKEY reads one terminal keystroke to stack
                           3567 ;
                           3568 ;
   1629 86 B5         [ 3] 3569 XKEY:      STX XSAVE
   162B 20 DC D1      [ 6] 3570           JSR INCH       ; might otherwise clobber it while
   162E A6 B5         [ 3] 3571           LDX XSAVE      ; inputting a char to accumulator
   1630 4C F4 05      [ 3] 3572           JMP PUSHOA
                           3573 ;
                           3574 ;         XQTER leaves a boolean representing terminal break
                           3575 ;
                           3576 ;
   1633 AD 00 C0      [ 4] 3577 XQTER:     LDA 0xC000      ; system depend port test
   1636 CD 01 C0      [ 4] 3578           CMP 0xC001
   1639 29 01         [ 2] 3579           AND #1
   163B 4C F4 05      [ 3] 3580           JMP PUSHOA
